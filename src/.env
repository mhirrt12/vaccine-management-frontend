# =====================================================
# Vaccine Management System - Environment Configuration
# =====================================================

# Application Settings
APP_NAME="Vaccine Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000/api

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vaccine_ms
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# JWT Authentication
JWT_SECRET=YourSuperSecretJWTKeyChangeThisInProduction1234567890!
JWT_EXPIRY=86400

# Mail Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@vaccine-ms.com
MAIL_FROM_NAME="VMS Ethiopia"

# SMS Configuration (Placeholder - integrate with local SMS provider)
SMS_ENABLED=false
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=VMS-Ethiopia

# Storage Paths
CERTIFICATE_STORAGE_PATH=/storage/certificates
REPORT_STORAGE_PATH=/storage/reports
LOG_PATH=/logs

# Rate Limiting (requests per minute)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# CORS Settings (for frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# System Settings
TIMEZONE=Africa/Addis_Ababa
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,am

# EPI Schedule (Ethiopian) - Reference
EPI_BIRTH_DAYS=0
EPI_6_WEEKS_DAYS=42
EPI_10_WEEKS_DAYS=70
EPI_14_WEEKS_DAYS=98
EPI_9_MONTHS_DAYS=274
EPI_15_MONTHS_DAYS=456

# Notification Settings
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false
APPOINTMENT_REMINDER_DAYS_BEFORE=1
STOCK_LOW_THRESHOLD=100
STOCK_EXPIRY_WARNING_DAYS=15

# Backup Settings
BACKUP_ENABLED=true
BACKUP_PATH=/backups
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# Audit Log Retention (days)
AUDIT_LOG_RETENTION_DAYS=90

# Session & Cookie
SESSION_LIFETIME=120
COOKIE_SECURE=false   # Set true if using HTTPS
COOKIE_HTTP_ONLY=true
COOKIE_SAMESITE=Strict